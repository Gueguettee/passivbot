{
  "meta_optimization": {
    "base_config": "configs/original/hype_dio_masterclass.json",
    "output_dir": "meta_optimize_results/hype_dio_bybit",

    "validation_scheme": {
      "type": "time_only",
      "time_folds": {
        "n_folds": 3,
        "train_months": 8,
        "val_months": 2,
        "mode": "rolling",
        "gap_months": 0
      }
    },

    "optimization_settings": {
      "iters_per_fold": 40000,
      "population_size": 500,
      "n_cpus": null,
      "early_stopping_patience": 5000,
      "early_stopping_min_improvement": 0.001
    },

    "robustness_weights": {
      "consistency": 0.4,
      "degradation": 0.3,
      "worst_case": 0.2,
      "stability": 0.1
    },

    "robustness_thresholds": {
      "min_profitable_folds_pct": 0.66,
      "max_degradation_ratio": 0.5,
      "max_cv_adg": 1.5,
      "min_worst_fold_adg": 0.0
    },

    "output_settings": {
      "top_n_configs": 10,
      "export_all_pareto": true,
      "generate_report": true,
      "save_validation_details": true
    },

    "execution_settings": {
      "n_parallel_backtests": 2,
      "checkpoint_interval_minutes": 15,
      "resume_from_checkpoint": true,
      "verbose": true,
      "log_level": "info"
    }
  }
}
